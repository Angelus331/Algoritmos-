#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;
    int arr[100][100];
    
    cout << "Los elementos de la matriz A: ";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> arr[i][j];
        }
    }
    cout << "\nLa matriz A es: " << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << arr[i][j] << " ";
        }
        cout << endl;
    }
    cout << endl;
    int err[100][100];
    cout << "Los elementos de la matriz B: ";
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> err[i][j];
        }
    }
    cout << "\nLa matriz B es: " << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << err[i][j] << " ";
        }
        cout << endl;
    }
    
    cout << "\nSuma de matrices:" << endl;
    int irr[100][100];
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            irr[i][j] = arr[i][j] + err[i][j];
            cout << irr[i][j] << " ";
        }
        cout << endl;
    }
    
    return 0;
}
