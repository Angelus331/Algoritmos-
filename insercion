def Insercion(A):  # Recorre desde la segunda posición
    for i in range(1, len(A)):
        aux = A[i]
        j = i - 1

        # Desplaza los elementos mayores que aux
        while j >= 0 and A[j] > aux:
            A[j + 1] = A[j]
            j = j - 1

        # Inserta el elemento
        A[j + 1] = aux


# Ejemplo (fuera de la función)
entrada = input("Ingresa los números separados por espacio: ")
lista = list(map(int, entrada.split()))

Insercion(lista)
print(lista)
