#include <iostream>
using namespace std;
 int fibonacci(int n) {
    if (n <= 1) {
        return n; // Base case: F(0) = 0, F(1) = 1
    }
    int a = 0, b = 1, c;
    for (int i = 2; i <= n; i++) {
        c = a + b; 
        a = b;     
        b = c;
    }
    return b; 

}
int main(){
    int n;
    cout << "ingrese terminos";
    cin >> n;
    cout << "el termino es" << fibonacci(n) << endl;
    return 0;
}
