#include <iostream>
using namespace std;
int fibonacci(int n) {
    if (n <= 1) {
        return n; // Base case: F(0) = 0, F(1) = 1
    }
    return fibonacci(n - 1) + fibonacci(n - 2); // Recursive case
}

int main() {
    int n;
    cout << "Ingrese el término de Fibonacci que desea calcular: ";
    cin >> n;
    cout << "El término de Fibonacci es: " << fibonacci(n) << endl;
    return 0;
}
